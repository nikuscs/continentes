      "html": "<div class=\"ct-tile-quantity d-none\" data-pid=\"6879912\">\n    <input type=\"hidden\" class=\"add-to-cart-url\" value=\"https://www.continente.pt/on/demandware.store/Sites-continente-Site/default/Cart-AddProduct\" />\n\n    <div class=\"d-none tile-delete-confirmation-btn\"\n        data-pid=\"6879912\"\n        data-delay-time=\"3000\"\n        data-in-cart-msg=\"no carrinho\"\n        data-one-product-added=\"Adicionado ao carrinho\"\n        data-remove-from-cart-msg=\"Removido do carrinho\"\n        data-stay-open=\"6000.0\"\n        data-confirmation-image=\"{&quot;url&quot;:&quot;https://www.continente.pt/dw/image/v2/BDVS_PRD/on/demandware.static/-/Sites-col-master-catalog/default/dw66d59f15/images/col/687/6879912-frente.jpg?sw=87&amp;sh=80&quot;,&quot;fallbackimage&quot;:{&quot;url&quot;:&quot;https://www.continente.pt/dw/image/v2/BDVS_PRD/on/demandware.static/Sites-continente-Site/-/default/dweb166559/images/noimagelarge_product.png?sw=87&amp;sh=80&quot;,&quot;title&quot;:&quot;Leite UHT Meio Gordo Continente&quot;,&quot;alt&quot;:&quot;Leite UHT Meio Gordo Continente&quot;},&quot;title&quot;:&quot;Leite UHT Meio Gordo Continente&quot;,&quot;alt&quot;:&quot;Leite UHT Meio Gordo Continente&quot;}\"\n    ></div>\n\n    \n\n\n    \n    \n\n\n\n\n\n\n\n<div class=\"ct-tile-quantity-update ct-tile-quantity-update-pid-6879912 quantity-update product-qty-vue align-content-center\"\n    data-remove-action=\"https://www.continente.pt/on/demandware.store/Sites-continente-Site/default/Cart-RemoveProductLineItem\"\n    data-action=\"https://www.continente.pt/on/demandware.store/Sites-continente-Site/default/Cart-UpdateQuantity\"\n    data-dimension-update=\"https://www.continente.pt/on/demandware.store/Sites-continente-Site/default/Cart-DimensionUpdate\"\n    data-pid=\"6879912\"\n    data-uuid=\"2d9bf3c61057f54f2671670a20\"\n    data-add-delay=\"500.0\"\n    data-measure-options=\"{&quot;hasConversionRate&quot;:false,&quot;hasAlternativeSaleUnit&quot;